[server]
transport = "http"
host = "0.0.0.0"
port = 8080
log_level = "info"
log_file = "/var/log/zabbix-mcp/server.log"
{% if zabbix_mcp.auth_token is defined and zabbix_mcp.auth_token %}
auth_token = "{{ zabbix_mcp.auth_token }}"
{% else %}
{{ 'auth_token is required when host is 0.0.0.0' | mandatory }}
{% endif %}
rate_limit = 300
compact_output = true

[zabbix.production]
url = "{{ zabbix_mcp.url }}"
api_token = "{{ zabbix_mcp.api_token }}"
read_only = {{ zabbix_mcp.read_only | lower }}
verify_ssl = true
