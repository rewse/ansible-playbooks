#!/usr/bin/bash
set -euo pipefail

# Configuration
readonly REMOTE="guppy:/volume1/Backup/{{ ansible_facts['hostname'] }}"
readonly MOUNT="/mnt/bak"

# Cleanup function
cleanup() {
  local exit_code="${1:-0}"

  if mountpoint -q "${MOUNT}"; then
    umount "${MOUNT}" || {
      echo "Warning: Failed to unmount ${MOUNT}" >&2
      exit_code=1
    }
  fi

  exit "${exit_code}"
}

# Set trap for cleanup
trap 'cleanup 1' INT TERM EXIT

# Mount remote if not already mounted
if ! mountpoint -q "${MOUNT}"; then
  mount "${REMOTE}" "${MOUNT}" || {
    echo "Error: Failed to mount ${REMOTE} to ${MOUNT}" >&2
    exit 1
  }
fi

# Verify repository integrity (reads all pack files)
nice -n 10 restic check --read-data --verbose

# Cleanup with success status
trap - INT TERM EXIT
cleanup 0
